# local.properties.example
#
# Copy this file to `local.properties` and fill in your own values.
# The real `local.properties` is git-ignored and must NEVER be committed.
#
#   cp local.properties.example local.properties
#
# ---------------------------------------------------------------------------

# Path to your local Android SDK.
# Android Studio normally generates this line for you automatically.
#   macOS / Linux example:  /Users/you/Library/Android/sdk
#   Windows example:        C\:\\Users\\you\\AppData\\Local\\Android\\Sdk
sdk.dir=/ABSOLUTE/PATH/TO/YOUR/Android/sdk

# ---------------------------------------------------------------------------
# EmailJS credentials (used by EmailService.kt for report notifications).
# Read at build time and exposed via BuildConfig — not hard-coded in source.
# Get these from your EmailJS dashboard.
# ---------------------------------------------------------------------------
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
